# --- REQUIRED ---

# Telegram Bot Configuration
# Get these from my.telegram.org and @BotFather
TG_BOT_TOKEN=
APP_ID=
API_HASH=
BOT_USERNAME=
ADMINS= # Space separated list of admin user IDs (e.g., 12345678 87654321)

# Database Configuration
# Set DATABASE_TYPE to 'postgres' or 'mongodb'. Defaults to 'postgres' if not set.
DATABASE_TYPE=
# Provide the connection URL for your chosen database.
# Postgres Example: postgresql://user:pass@host:port/db
# MongoDB Example:  mongodb+srv://user:pass@cluster.mongodb.net/
DATABASE_URL=
# If your MongoDB URL does not specify a database, you must provide it below.
MONGODB_DATABASE=


# --- OPTIONAL ---

# Working Directory
# These are the default paths. You probably don't need to change them.
WORK_DIR=./bot/
DOWNLOADS_FOLDER=DOWNLOADS
LOCAL_STORAGE=./bot/DOWNLOADS

# File/Folder Naming Format
# You can use placeholders like {title}, {artist}, {album}, etc.
PLAYLIST_NAME_FORMAT={title} - Playlist
TRACK_NAME_FORMAT={title} - {artist}

# Dump Channel: Send a copy of all downloads to a specific channel
# To enable, set DUMP_CHANNEL_ENABLED to True and provide the channel ID.
DUMP_CHANNEL_ENABLED=False # 'True' or 'False'
DUMP_CHANNEL_MODE=Both # 'Both' (send to user and channel) or 'Only' (send to channel only)
DUMP_CHANNEL_ID= # The numeric ID of your channel (e.g., -1001234567890)

# Rclone/Index Configuration (only used if you enable Rclone uploads in bot settings)
# You can get a pre-made rclone.conf from a URL or provide a local path.
RCLONE_CONFIG=
# The destination on your rclone remote (e.g., "remote:MyMusic")
RCLONE_DEST=
# An optional public index link for your rclone destination.
INDEX_LINK=

# Concurrent Workers
# How many downloads/uploads can run at the same time.
MAX_WORKERS=5

# Apple Music Configuration
# These are the default paths. You probably don't need to change them.
DOWNLOADER_PATH=/usr/src/app/downloader/am_downloader.sh
INSTALLER_PATH=/usr/src/app/downloader/install_am_downloader.sh
APPLE_DEFAULT_FORMAT=alac  # 'alac' or 'atmos'
APPLE_ALAC_QUALITY=192000  # 192000, 256000, 320000
APPLE_ATMOS_QUALITY=2768   # Only one option for Atmos
# Apple Wrapper script paths (optional, use if you move the scripts)
APPLE_WRAPPER_SETUP_PATH=/usr/src/app/downloader/setup_wrapper.sh
APPLE_WRAPPER_STOP_PATH=/usr/src/app/downloader/stop_wrapper.sh


# --- DEPRECATED / ADVANCED ---
# These are legacy settings and may not be needed for an Apple Music-only setup.

# Qobuz Configuration
QOBUZ_EMAIL=
QOBUZ_PASSWORD=
QOBUZ_USER=
QOBUZ_TOKEN=
#QOBUZ_QUALITY=7

# Deezer Configuration
DEEZER_EMAIL=
DEEZER_PASSWORD=
DEEZER_BF_SECRET=
DEEZER_ARL=

# Tidal Configuration
ENABLE_TIDAL=False
TIDAL_MOBILE=False
TIDAL_MOBILE_TOKEN=
TIDAL_ATMOS_MOBILE_TOKEN=
TIDAL_TV_TOKEN=
TIDAL_TV_SECRET=
TIDAL_CONVERT_M4A=False
TIDAL_REFRESH_TOKEN=
TIDAL_COUNTRY_CODE=US
#TIDAL_QUALITY=LOSSLESS
#TIDAL_SPATIAL=ATMOS AC4
#TIDAL_NG_DOWNLOAD_BASE_PATH=