# Telegram Bot Configuration
TG_BOT_TOKEN=
APP_ID=
API_HASH=
BOT_USERNAME=
ADMINS=

# Database Configuration
# Set DATABASE_TYPE to 'postgres' or 'mongodb'. Defaults to 'postgres' if not set.
DATABASE_TYPE=mongodb
# Provide the connection URL for your chosen database.
# Postgres Example: postgresql://user:pass@host:port/db
# MongoDB Example:  mongodb+srv://user:pass@cluster.mongodb.net/
# If your MongoDB URL does not specify a database, you must provide it below.
MONGODB_DATABASE=
DATABASE_URL=

# Working Directory
WORK_DIR=./bot/
DOWNLOADS_FOLDER=DOWNLOADS
LOCAL_STORAGE=./bot/DOWNLOADS

# File/Folder Naming
PLAYLIST_NAME_FORMAT={title} - Playlist
TRACK_NAME_FORMAT={title} - {artist}

# Rclone/Index Configuration (only for UPLOAD_MODE=RCLONE)
RCLONE_CONFIG=
RCLONE_DEST=
INDEX_LINK=

# Qobuz Configuration (optional)
QOBUZ_EMAIL=
QOBUZ_PASSWORD=
QOBUZ_USER=
QOBUZ_TOKEN=

# Deezer Configuration (optional)
DEEZER_EMAIL=
DEEZER_PASSWORD=
DEEZER_BF_SECRET=
DEEZER_ARL=

# Tidal Configuration (optional)
ENABLE_TIDAL=False
TIDAL_MOBILE=False
TIDAL_MOBILE_TOKEN=
TIDAL_ATMOS_MOBILE_TOKEN=
TIDAL_TV_TOKEN=
TIDAL_TV_SECRET=
TIDAL_CONVERT_M4A=False
TIDAL_REFRESH_TOKEN=
TIDAL_COUNTRY_CODE=US

# Concurrent Workers
MAX_WORKERS=5

# Apple Music Configuration
DOWNLOADER_PATH=/usr/src/app/downloader/am_downloader.sh
INSTALLER_PATH=/usr/src/app/downloader/install_am_downloader.sh
APPLE_DEFAULT_FORMAT=alac
APPLE_ALAC_QUALITY=192000
APPLE_ATMOS_QUALITY=2768
APPLE_WRAPPER_SETUP_PATH=/usr/src/app/downloader/setup_wrapper.sh
APPLE_WRAPPER_STOP_PATH=/usr/src/app/downloader/stop_wrapper.sh

# Upload Mode: Telegram, RCLONE, or Local
UPLOAD_MODE=Telegram

# Optional Settings
EXTRACT_EMBEDDED_COVER=True
